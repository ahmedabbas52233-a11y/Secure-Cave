# ── Server ───────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/securecave
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/securecave
MONGODB_URI=mongodb://localhost:27017/securecave

# ── JWT ───────────────────────────────────────────────────────────────
# Generate a secure secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────
# In production, set this to your deployed frontend URL
FRONTEND_URL=http://localhost:5173
